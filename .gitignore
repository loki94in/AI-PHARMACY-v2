# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Environment / Secrets ───────────────────────────────────────────────────
.env
.env.*
.env*.local
!.env.example

# ─── SQLite Databases & Backups ──────────────────────────────────────────────
data/*.db
data/*.db-shm
data/*.db-wal
data/*.db.bak*
data/*.db.bak*-shm
data/*.db.bak*-wal
data/*.corrupt
data/*backup*
data/app.test.db*
backup/
data/temp_migration/
data/migration_reports/
data/cache/
data/staging.db
data/archived_migrations/

# ─── Live Operational Data (never commit runtime exports) ────────────────────
data/audit_queue.json
data/ocr_corrections.json
data/search_screenshots/
data/temp_ocr/
data/audit_images/

# ─── Media Uploads & Temp files ──────────────────────────────────────────────
uploads/
**/uploads/
uploads/temp/

# ─── Build Outputs & Cache ───────────────────────────────────────────────────
dist/
**/dist/
.expo/
**/.expo/
web-build/
**/web-build/

# ─── WhatsApp Auth Cache ─────────────────────────────────────────────────────
.wwebjs_auth/
.wwebjs_cache/
**/.wwebjs_auth/
**/.wwebjs_cache/

# ─── OCR Models & Training Data (large binaries — download at runtime) ───────
data/models/
eng.traineddata

# ─── SQL Dumps ───────────────────────────────────────────────────────────────
*.sql

# ─── IDE / Tool Caches ───────────────────────────────────────────────────────
.understand-anything/
.codegraph/
.opencode/

# ─── Graphify & Knowledge Graph (generated — run node scripts/quick-update.mjs) ──
graphify-out/
3d-knowledge-graph.html

# ─── Scratch / Dev-Only Debug Scripts ────────────────────────────────────────
# These are one-off investigation scripts, not production code.
# Files stay on disk but are not shared via git.
scratch/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
**/logs/

# ─── Misc Temp / Test Artifacts ──────────────────────────────────────────────
temp.json
test.csv

# ─── Large Archives and Database Backups ─────────────────────────────────────
*.zip
*.bak
MIGRATION SAMPEL/

# ─── Large Binary Data Files (120 MB — too large for git) ────────────────────
# Download from release assets or team shared drive.
medicines.csv

# ─── Distributor Catalogs (binary PDFs — bloat repo history) ─────────────────
# Store in shared drive / release assets instead.
CATALOG/

# ─── Puppeteer Pharmarack Browser Session Profiles ───────────────────────────
# Chrome browser session data — thousands of files, never commit
data/pharmarack_profile/
data/pharmarack_profile_temp_*/

# ─── Python Virtual Environments & Cache ──────────────────────────────────────
.venv/
venv/
**/__pycache__/
**/*.pyc
