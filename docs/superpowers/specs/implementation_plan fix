#### 4.1 — Implement `handleMedicineQuery` in TelegramBot
**File:** [telegramBot.ts](file:///E:/CURRENT%20PROJECT%20ON%20WORKING/AI%20PHARMACY/src/telegramBot.ts)
```ts
private async handleMedicineQuery(chatId: number, medicineName: string) {
  const db = await open({ filename: DB_PATH, driver: sqlite3.Database });
  const medicine = await db.get(
    `SELECT m.name, m.mrp, im.quantity FROM medicines m 
     LEFT JOIN inventory_master im ON im.medicine_id = m.id 
     WHERE LOWER(m.name) LIKE ? ORDER BY im.quantity DESC LIMIT 1`,
    [`%${medicineName}%`]
  );
  await db.close();
  if (!medicine) {
    this.bot?.sendMessage(chatId, `❌ Medicine "${medicineName}" not found in database.`);
  } else if (medicine.quantity > 0) {
    this.bot?.sendMessage(chatId, `✅ ${medicine.name}\n💰 MRP: ₹${medicine.mrp}\n📦 Stock: ${medicine.quantity} units`);
  } else {
    this.bot?.sendMessage(chatId, `⚠️ ${medicine.name} is OUT OF STOCK.\n💰 MRP: ₹${medicine.mrp}`);
  }
}
```

