{
  "name": "ai-pharmacy",
  "version": "0.1.0",
  "type": "module",
  "bin": "src/server.ts",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:client": "npm run dev --prefix frontend",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests --forceExit",
    "enqueue-catalog": "tsx ./src/cli/enqueueCatalog.ts",
    "worker": "tsx ./src/worker/catalogWorker.ts",
    "watch-catalog": "tsx ./src/cli/watchCatalog.ts",
    "build:exe": "pkg . --targets node18-win-x64 --output dist/PharmacyOS.exe"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.16.1",
    "better-sqlite3": "^12.10.0",
    "canvas": "^3.2.3",
    "chokidar": "^3.6.0",
    "cors": "^2.8.6",
    "csv-parse": "^5.5.2",
    "csv-parser": "^3.2.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "imap-simple": "^1.6.3",
    "jimp": "^1.6.1",
    "mailparser": "^3.9.8",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.66.0",
    "nodemailer": "^8.0.8",
    "onnxruntime-node": "^1.26.0",
    "paddleocr": "^1.1.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^6.0.227",
    "pdfkit": "^0.13.0",
    "puppeteer-core": "^25.1.0",
    "qrcode": "^1.5.4",
    "sqlite": "^5.0.2",
    "sqlite3": "^6.0.1",
    "tesseract.js": "^7.0.0",
    "unzipper": "^0.12.3",
    "whatsapp-web.js": "^1.22.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/imap-simple": "^4.2.10",
    "@types/jest": "^29.5.2",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.13",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/sqlite3": "^3.1.11",
    "@types/supertest": "^7.2.0",
    "@types/unzipper": "^0.10.11",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "jest": "^29.6.0",
    "node-gyp": "^12.3.0",
    "pkg": "^5.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "pkg": {
    "assets": [
      "data/**",
      "backup/**"
    ]
  },
  "overrides": {
    "qs": "^6.15.2",
    "request": {
      "form-data": "^2.5.4",
      "tough-cookie": "^4.1.3"
    },
    "utf7": {
      "semver": "^5.7.2"
    },
    "uuid": "^11.1.1",
    "xml2js": "^0.5.0"
  }
}
